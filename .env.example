# ==================== APPLICATION ====================
APP_ENV=development
LOG_LEVEL=INFO
SERVICE_NAME=ingestor

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== KAFKA ====================
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=raw.metrics.v1
KAFKA_ACKS=all
KAFKA_RETRIES=3
KAFKA_COMPRESSION=gzip

# ==================== RATE LIMITING ====================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# ==================== SECURITY ====================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30